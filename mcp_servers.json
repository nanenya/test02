{
  "version": "1.0",
  "servers": [
    {
      "name": "filesystem",
      "package": "@modelcontextprotocol/server-filesystem",
      "package_manager": "npm",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "env": null,
      "enabled": true,
      "added_at": "2026-02-18",
      "description": "MCP filesystem server for file operations"
    },
    {
      "name": "git",
      "package": "mcp-server-git",
      "package_manager": "pip",
      "command": "mcp-server-git",
      "args": [],
      "env": null,
      "enabled": true,
      "added_at": "2026-02-18",
      "description": "MCP git server for version control operations"
    },
    {
      "name": "fetch",
      "package": "mcp-server-fetch",
      "package_manager": "pip",
      "command": "mcp-server-fetch",
      "args": [],
      "env": null,
      "enabled": true,
      "added_at": "2026-02-18",
      "description": "MCP fetch server for HTTP requests"
    },
    {
      "name": "sqlite",
      "package": "mcp-server-sqlite",
      "package_manager": "pip",
      "command": "uvx",
      "args": ["mcp-server-sqlite", "--db-path", "$CWD/history/conversations.db"],
      "env": null,
      "enabled": true,
      "added_at": "2026-03-03",
      "description": "SQLite DB 직접 쿼리 - conversations.db, system_prompts, issues 등 모든 테이블 접근 가능"
    },
    {
      "name": "duckduckgo",
      "package": "duckduckgo-mcp",
      "package_manager": "npm",
      "command": "npx",
      "args": ["-y", "duckduckgo-mcp"],
      "env": null,
      "enabled": true,
      "added_at": "2026-03-03",
      "description": "DuckDuckGo 웹 검색 (완전 무료, API 키 불필요) - brave-search 대체"
    },
    {
      "name": "memory",
      "package": "@modelcontextprotocol/server-memory",
      "package_manager": "npm",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": null,
      "enabled": true,
      "added_at": "2026-03-03",
      "description": "영구 KV 그래프 메모리 - 에이전트 장기 기억, 엔티티-관계 구조화 저장 (세션 간 유지)"
    },
    {
      "name": "docker",
      "package": "mcp-server-docker",
      "package_manager": "pip",
      "command": "mcp-server-docker",
      "args": [],
      "env": null,
      "enabled": false,
      "added_at": "2026-03-03",
      "description": "Docker 컨테이너 관리 - 격리된 코드 실행 샌드박스. pip 설치 완료. 활성화 전 필수: Docker 엔진 설치 및 데몬 실행 (docker info 확인)"
    },
    {
      "name": "context7",
      "package": "@upstash/context7-mcp",
      "package_manager": "npm",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": null,
      "enabled": true,
      "added_at": "2026-03-03",
      "description": "라이브러리 최신 문서·코드 예시 컨텍스트 제공 - 프롬프트에 'use context7' 추가로 활성화"
    },
    {
      "name": "playwright",
      "package": "@playwright/mcp",
      "package_manager": "npm",
      "command": "npx",
      "args": ["-y", "@playwright/mcp"],
      "env": null,
      "enabled": true,
      "added_at": "2026-03-03",
      "description": "브라우저 자동화 (Playwright) - 웹 스크래핑, 폼 작성, 스크린샷, JS 렌더링 페이지 처리"
    },
    {
      "name": "github",
      "package": "@modelcontextprotocol/server-github",
      "package_manager": "npm",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {"GITHUB_PERSONAL_ACCESS_TOKEN": ""},
      "enabled": false,
      "added_at": "2026-03-03",
      "description": "GitHub API - issues, PRs, repos, code search. 활성화 전 필수: env.GITHUB_PERSONAL_ACCESS_TOKEN"
    },
    {
      "name": "sequential-thinking",
      "package": "@modelcontextprotocol/server-sequential-thinking",
      "package_manager": "npm",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "env": null,
      "enabled": true,
      "added_at": "2026-03-03",
      "description": "단계적 구조화 추론 도구 - 복잡한 문제를 순차 사고로 분해하여 품질 높은 계획 생성"
    },
    {
      "name": "vercel",
      "package": "mcp-remote",
      "package_manager": "npm",
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.vercel.com/sse"],
      "env": null,
      "enabled": true,
      "on_demand": true,
      "added_at": "2026-03-03",
      "description": "Vercel 배포/프로젝트 관리 (Remote MCP, 온디맨드). 첫 사용 시 브라우저 OAuth 인증 필요"
    },
    {
      "name": "serena",
      "package": "git+https://github.com/oraios/serena",
      "package_manager": "pip",
      "command": "uvx",
      "args": ["--from", "git+https://github.com/oraios/serena", "serena-mcp-server", "--project-from-cwd"],
      "env": null,
      "enabled": true,
      "added_at": "2026-03-03",
      "description": "LSP 기반 코드 인텔리전스 (oraios/serena) - 심볼 검색·네비게이션·리팩터링. uvx로 자동 설치"
    },
    {
      "name": "postgres",
      "package": "@modelcontextprotocol/server-postgres",
      "package_manager": "npm",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "postgresql://localhost/mydb"],
      "env": null,
      "enabled": false,
      "added_at": "2026-03-03",
      "description": "PostgreSQL DB 쿼리 (완전 무료) - supabase 대체. args[2]의 연결 URL을 실제 DB로 수정 필요. 로컬 PG 또는 Neon/Supabase 무료 티어 사용 가능"
    }
  ],
  "tool_name_aliases": {
    "read_file": "read_file",
    "write_file": "write_file",
    "create_directory": "create_directory",
    "list_directory": "list_directory",
    "move": "move_file",
    "find_files": "search_files",
    "get_file_size": "get_file_info",
    "path_exists": "get_file_info",
    "is_file": "get_file_info",
    "is_directory": "get_file_info",
    "git_status": "git_status",
    "git_add": "git_add",
    "git_commit": "git_commit",
    "git_push": "git_push",
    "git_pull": "git_pull",
    "git_log": "git_log",
    "git_diff": "git_diff",
    "git_clone": "git_clone",
    "git_init": "git_init",
    "git_create_branch": "git_create_branch",
    "git_list_branches": "git_branch",
    "git_checkout": "git_checkout",
    "git_show": "git_show",
    "fetch_url_content": "fetch",
    "api_get_request": "fetch",
    "api_post_request": "fetch",
    "download_file_from_url": "fetch",
    "get_modification_time": "get_file_info",
    "get_creation_time": "get_file_info",
    "rename": "move_file",
    "find_text_in_files": "search_for_pattern",
    "replace_text_in_file": "replace_content",
    "fetch_dynamic_content": "browser_navigate",
    "execute_sql_query": "write_query",
    "read_code_file": "read_file",
    "get_function_signature": "find_symbol",
    "get_git_status": "git_status",
    "web_search": "duckduckgo_search",
    "search_web": "duckduckgo_search",
    "browser_open": "browser_navigate",
    "browser_go": "browser_navigate",
    "run_in_docker": "docker_run",
    "execute_in_container": "docker_run",
    "remember": "create_entities",
    "recall": "search_nodes",
    "think_step_by_step": "sequentialthinking",
    "sequential_think": "sequentialthinking",
    "get_docs": "get-library-docs",
    "resolve_library": "resolve-library-id"
  }
}
